# codex-bridge configuration (OPTIONAL).
#
# The one-click binary stores its config in a per-OS JSON file and is configured
# through the local GUI (http://127.0.0.1:8788) — you normally don't need a .env.
#
# Use this file only if you prefer environment configuration (e.g. headless / CI).
# Environment values OVERRIDE the config file and appear read-only in the GUI.
#
# Note: the binary auto-loads a `.env` in its working directory. With `node`, load
# it via `node --env-file=.env` (reads values literally — no shell quote-stripping).

# Strong random bearer key the dashboard must send (Authorization: Bearer ...).
# Leave UNSET to have the bridge auto-generate one on first run. Generate manually:
# openssl rand -hex 32
CODEX_BRIDGE_API_KEY=

# Repos codex may operate on. JSON array of { url, path }. Editable in the GUI.
# url  = the repo URL the dashboard allowlists (matched normalized: no proto / .git / trailing slash)
# path = absolute local checkout on THIS machine, used as codex cwd (can be any folder)
CODEX_BRIDGE_REPOS=[{"url":"github.com/acme/repo","path":"/srv/repos/repo"}]

# API bind address / port. Keep on localhost and put a TLS reverse proxy in front.
CODEX_BRIDGE_HOST=127.0.0.1
CODEX_BRIDGE_PORT=8787

# Admin/config GUI port (loopback only — never put behind the TLS proxy).
CODEX_BRIDGE_ADMIN_PORT=8788
# If set, the admin API also requires Authorization: Bearer <token>.
# CODEX_BRIDGE_ADMIN_TOKEN=

# codex execution policy. 'never' = auto-approve everything (no prompts).
CODEX_APPROVAL_POLICY=never
# Sandbox = what codex may touch (app-server tokens):
#   read-only           -> read only
#   workspace-write     -> read all, WRITE/RUN only inside the repo path (cwd). Network OFF
#                          by default. This is the "free, but locked to a folder" mode.
#   danger-full-access  -> NO sandbox: full machine + network. Use only if you really want it.
#   config            -> don't override on the wire; use ~/.codex/config.toml instead
#                        (set sandbox_mode / [sandbox_workspace_write] network_access /
#                        writable_roots / danger-full-access there with the kebab-case values).
CODEX_SANDBOX=workspace-write
# Defensive net for the rare approval request that still arrives: false declines all.
CODEX_AUTO_APPROVE=true

# Optional default model id for launches.
# CODEX_MODEL=

# Optional path to a JSONL audit log (every launch/followup/cancel/approval).
# CODEX_BRIDGE_AUDIT_LOG=/var/log/codex-bridge/audit.log

# codex binary (default: `codex` on PATH).
# CODEX_BIN=codex

# Request logging: one line per HTTP request (API + admin) on stdout. Never logs
# the Authorization header or query string. Default on; set to 0/false to disable.
# CODEX_BRIDGE_REQUEST_LOG=true
# Optional JSONL access-log file for requests.
# CODEX_BRIDGE_REQUEST_LOG_FILE=/var/log/codex-bridge/access.jsonl

# Override the config-file location (default: per-OS app config dir).
# CODEX_BRIDGE_CONFIG=/etc/codex-bridge/config.json

# Set to 1 to suppress auto-opening the browser on launch.
# CODEX_BRIDGE_NO_OPEN=1

# Set to 1 to log every raw codex notification (use when adapting to a new codex version).
# CODEX_BRIDGE_DEBUG=1
